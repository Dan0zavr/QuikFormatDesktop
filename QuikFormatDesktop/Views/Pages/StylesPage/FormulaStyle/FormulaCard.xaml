<UserControl x:Class="QuikFormatDesktop.View.Pages.FormulaCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.View.Pages"
             mc:Ignorable="d">
    
    <GroupBox Header="Стиль формулы" FontSize="12" Background="{StaticResource MainBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!--Имя стиля-->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Имя стиля:" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="ParagraphStyleName" FontSize="12" Margin="0,0,0,5" Text="{Binding ParagraphStyleName}"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Положение" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Rows="1" Margin="0,0,0,5">
                        <RadioButton GroupName="Alignment" Style="{StaticResource LeftIndent}"/>
                        <RadioButton GroupName="Alignment" Style="{StaticResource CenterIndent}"/>
                        <RadioButton GroupName="Alignment" Style="{StaticResource BothIndent}"/>
                        <RadioButton GroupName="Alignment" Style="{StaticResource RightIndent}"/>
                    </UniformGrid>

                    <StackPanel Grid.Row="1" Margin="0, 5, 0, 0" Orientation="Horizontal">
                        <TextBlock Text="Пустые строки перед и после рисунка" FontSize="12" Margin="0, 0, 5, 0"/>
                        <CheckBox VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Нумерация" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Нумерация" FontSize="12" VerticalAlignment="Center"/>
                        <CheckBox Margin="5, 0, 0, 0" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0, 5, 0, 0" Orientation="Horizontal">
                        <TextBlock Text="Формат нумерации" FontSize="12"/>
                        <ComboBox FontSize="12" Margin="5, 0, 0, 0" Width="60"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="6" VerticalAlignment="Bottom" HorizontalAlignment="Right" >
                <TextBlock Text="{Binding PStatusMessage}" 
            Foreground="Green" 
            FontWeight="Bold"
            Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" >
                    <Button Content="Сброс" Width="100" Margin="0,0,10,0" Command="{Binding TextDeleteCommand}"/>
                    <Button Content="Сохранить" Width="100" Command="{Binding AddParagraphCommand}"/>

                </StackPanel>
            </StackPanel>
        </Grid>
    </GroupBox>
</UserControl>
