<UserControl x:Class="QuikFormatDesktop.Views.Pages.StylesPage.PictureStyle.ShortPictureMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220">

    <Border Background="{StaticResource BackColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Название -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BaseText}"
                       FontWeight="SemiBold"/>

            <!-- Основная информация -->
            <StackPanel Grid.Row="1" Margin="0,10,0,0">

                <!-- Абзац -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Абзац:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding ParagraphStyleNavigation.Name}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Подпись -->
                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Подпись:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Margin="5,0,0,0"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BaseText}">
                                <Setter Property="Text" Value="нет"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GenerateLabel}" Value="True">
                                        <Setter Property="Text" Value="{Binding LabelValue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Пустые строки -->
                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Отступы:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Margin="5,0,0,0"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BaseText}">
                                <Setter Property="Text" Value="нет"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmptyLineAround}" Value="True">
                                        <Setter Property="Text" Value="да"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

            </StackPanel>

            <!-- Подробнее -->
            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Left"
                       Cursor="Hand"
                       Foreground="{StaticResource ForeColor}"
                       FontSize="12"
                       TextDecorations="Underline">
                Подробнее
            </TextBlock>

            <!-- Кнопки -->
            <UniformGrid Grid.Row="3"
                         Margin="0,15,0,0"
                         Columns="2">

                <Button Content="Удалить"
                        Style="{StaticResource DangerButton}"
                        FontSize="12"
                        Margin="2"/>

                <Button Content="Обновить"
                        Style="{StaticResource BaseButton}"
                        FontSize="12"
                        Margin="2"/>
            </UniformGrid>

        </Grid>
    </Border>
</UserControl>