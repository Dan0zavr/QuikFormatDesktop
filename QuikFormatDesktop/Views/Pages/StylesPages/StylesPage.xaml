<UserControl x:Class="QuikFormatDesktop.Views.Pages.StylesPage1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.Views.Pages"
             xmlns:vms="clr-namespace:QuikFormatDesktop.ViewModels.StylesViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="650">
    
    <Grid Background="{StaticResource MainBackground}">
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem x:Name="TextStyle">
                <TabItem.Header>
                    <TextBlock Text="Стиль текста"/>
                </TabItem.Header>
                <TabItem.Content>
                    <ContentControl Content="{Binding TextStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:TextStylePage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Стиль списков"/>
                </TabItem.Header>
                <TabItem.Content>
                    <ContentControl Content="{Binding NumberingStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:NumberingPage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Стиль таблиц"/>
                </TabItem.Header>
                <TabItem.Content>
                    <ContentControl Content="{Binding TableStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:TablePage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Стиль рисунков"/>
                </TabItem.Header>
                <TabItem.Content>
                    <ContentControl Content="{Binding PictureStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:PicturePage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Стиль формул"/>
                </TabItem.Header>
                <TabItem.Content>
                    <ContentControl Content="{Binding FormulaStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:FormulaPage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Глобальный стиль"/>
                </TabItem.Header>

                <TabItem.Content>
                    <ContentControl Content="{Binding GlobalStyleViewModel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <local:GlobalPage/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </TabItem.Content>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
