<UserControl x:Class="QuikFormatDesktop.Views.Pages.GlobalCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.Views.Pages"
             xmlns:enums="clr-namespace:QuikFormatDesktop.ViewModels.Enums"
             xmlns:converters="clr-namespace:QuikFormatDesktop.Views.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisible"/>
        <converters:ColorToHexConverter x:Key="ColorToHex"/>
    </UserControl.Resources>

    <GroupBox Header="{Binding CardName}" FontSize="14" Padding="4" Background="{StaticResource MainBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!--Имя стиля-->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Имя стиля:" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="GlobalStyleName" FontSize="12" Margin="0,0,0,5" Text="{Binding GlobalStyleName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!--Сообщение об ошибке валидации-->
            <TextBlock Grid.Row="1" Text="{Binding ValidationError}" Foreground="Red" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" Visibility="{Binding ValidationError, Converter={StaticResource BoolToVis}}"/>

            <!--Выравнивание-->
            <Grid Grid.Row="2" Margin="0, 10, 0, 0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Выравнивание" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>
                <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,5">
                    <RadioButton GroupName="Alignment" Style="{StaticResource LeftAlignment}" 
                                 IsChecked="{Binding SelectedAlignment,
                                 Converter={StaticResource EnumToBooleanConverter},
                                 ConverterParameter={x:Static enums:AlignmentType.Left}}"/>
                    <RadioButton GroupName="Alignment" Style="{StaticResource CenterAlignment}"
                                 IsChecked="{Binding SelectedAlignment,
                                 Converter={StaticResource EnumToBooleanConverter},
                                 ConverterParameter={x:Static enums:AlignmentType.Center}}"/>
                    <RadioButton GroupName="Alignment" Style="{StaticResource BothAlignment}"
                                 IsChecked="{Binding SelectedAlignment,
                                 Converter={StaticResource EnumToBooleanConverter},
                                 ConverterParameter={x:Static enums:AlignmentType.Both}}"/>
                    <RadioButton GroupName="Alignment" Style="{StaticResource RightAlignment}"
                                 IsChecked="{Binding SelectedAlignment,
                                 Converter={StaticResource EnumToBooleanConverter},
                                 ConverterParameter={x:Static enums:AlignmentType.Right}}"/>
                </UniformGrid>
            </Grid>

            <!--Поля документа-->
            <Grid Grid.Row="4" Margin="0, 10, 0, 0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Поля документа (см)" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition MaxWidth="100"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition MaxWidth="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Слева:" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding LeftMargin, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="Справа:" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Margin="5,0,0,0" Text="{Binding RightMargin, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition MaxWidth="100"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition MaxWidth="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Сверху:" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding TopMargin, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="Снизу:" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="3" Margin="5,0,0,0" Text="{Binding BottomMargin, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Grid>

            <!--Специальный колонтитул-->
            <Grid Grid.Row="6" Margin="0, 10, 0, 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding UseSpecialColontitul}"/>
                    <TextBlock Margin="5,0,0,0" Text="Использовать специальный колонтитул" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,5,0,0" Visibility="{Binding UseSpecialColontitul, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Текст колонтитула" FontSize="12" Margin="0,0,5,5"/>
                        <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBox Grid.Row="1" FontSize="12" Text="{Binding SpecialColontitul, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Grid>

            <!--Последняя страница без нумерации-->
            <Grid Grid.Row="8" Margin="0, 10, 0, 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding UseLastNoNumberingPage}"/>
                    <TextBlock Margin="5,0,0,0" Text="Последняя страница без нумерации" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,5,0,0" Visibility="{Binding UseLastNoNumberingPage, Converter={StaticResource BoolToVis}}" Orientation="Horizontal">
                    <TextBlock FontSize="12" Text="Номер страницы (если 0 - выключено):" VerticalAlignment="Center"/>
                    <TextBox Margin="5,0,0,0" Width="80" FontSize="12" Text="{Binding LastNoNumberingPage, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!--Кнопки-->
            <StackPanel Grid.Row="16" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <Button Content="Сброс" Width="100" Margin="0,0,10,0" Command="{Binding ResetCommand}" Visibility="{Binding IsAddMode, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Отмена" Width="100" Margin="0,0,10,0" Command="{Binding ResetCommand}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" x:Name="ForPopup">
                        <Button Content="Добавить" Width="100" Command="{Binding AddGlobalStyleCommand}" IsEnabled="{Binding IsValid}" Visibility="{Binding IsAddMode, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Обновить" Width="100" Command="{Binding UpdateGlobalStyleCommand}" IsEnabled="{Binding IsValid}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Popup IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=ForPopup}"
                           StaysOpen="False">
                        <Border Background="{Binding PopupBackground, Converter={StaticResource ColorToHex}}" Padding="7" MaxWidth="150">
                            <TextBlock Text="{Binding PopupMessage}" TextWrapping="WrapWithOverflow" Foreground="{Binding PopupForeground, Converter={StaticResource ColorToHex}}" FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                    </Popup>
                </StackPanel>
            </StackPanel>
        </Grid>
    </GroupBox>
</UserControl>
