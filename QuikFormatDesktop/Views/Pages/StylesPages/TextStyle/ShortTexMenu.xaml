<UserControl x:Class="QuikFormatDesktop.Views.Pages.ShortTextMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220">

    <Border Background="{StaticResource BackColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BaseText}"
                       FontWeight="SemiBold"/>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Шрифт:" Style="{StaticResource BaseText}" FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding FontName}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Размер:" Style="{StaticResource BaseText}" FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding FontSize}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>
            </Grid>

            

            <UniformGrid Grid.Row="2"
                         Margin="0,15,0,0"
                         Columns="2">

                <Button Content="Удалить"
                        Style="{StaticResource DangerButton}"
                        FontSize="12"
                        Margin="2"/>

                <Button Content="Подробнее"
                        Style="{StaticResource BaseButton}"
                        FontSize="12"
                        Margin="2"/>
            </UniformGrid>

        </Grid>
    </Border>
</UserControl>