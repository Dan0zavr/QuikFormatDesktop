<UserControl x:Class="QuikFormatDesktop.Views.Pages.TextCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.Views.Pages"
             xmlns:converters="clr-namespace:QuikFormatDesktop.Views.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisible"/>
        <converters:ColorToHexConverter x:Key="ColorToHex"/>
    </UserControl.Resources>

    <GroupBox Grid.Column="0" Header="{Binding CardName}" FontSize="14" Padding="4" Background="{StaticResource MainBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Имя стиля:" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="FontStyleName" FontSize="12" Margin="0,0,0,15" Text="{Binding StyleName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            
            <Grid Grid.Row="2">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Параметры" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Шрифт:" FontSize="12"/>
                        <ComboBox Margin="0,0,5,10" 
                                ItemsSource="{Binding Fonts}" 
                                SelectedItem="{Binding SelectedFont}"
                                DisplayMemberPath="FontName"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Margin="5, 0, 0, 0" Text="Размер:" FontSize="12"/>
                        <ComboBox Margin="5,0,0,10" 
                                ItemsSource="{Binding FontSizes}"
                                SelectedItem="{Binding SelectedFontSize}">
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="4" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel>
                        <Button Content="Сброс" Width="100" Margin="0,0,10,0" Command="{Binding ResetCommand}" Visibility="{Binding IsEdit, Converter={StaticResource InverseBoolToVisible}}"/>
                        <Button Content="Отмена" Width="100" Margin="0,0,10,0" Command="{Binding CancelCommand}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" x:Name="ForPopup">
                        <Button Content="Добавить" Width="100" Command="{Binding AddTextCommand}" Visibility="{Binding IsEdit, Converter={StaticResource InverseBoolToVisible}}"/>
                        <Button Content="Обновить" Width="100" Command="{Binding UpdateTextCommand}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    <Popup IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=ForPopup}"
                           StaysOpen="False">
                        <Border Background="{Binding PopupBackground, Converter={StaticResource ColorToHex}}" Padding="7" MaxWidth="100">
                            <TextBlock Text="{Binding PopupMessage}" TextWrapping="WrapWithOverflow" Foreground="{Binding PopupForeground, Converter={StaticResource ColorToHex}}" FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
