<UserControl x:Class="QuikFormatDesktop.Views.Pages.ShortParagraphMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220">

    <Border Background="{StaticResource BackColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BaseText}"
                       FontWeight="SemiBold"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Выравнивание:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding Alignment}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Отступы:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding LeftIndent}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Text=" / "
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Text="{Binding RightIndent}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Интервал:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding Interval}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

            </StackPanel>

            <Grid Grid.Row="2" Margin="0,15,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>


                <Button Grid.Column="0"
                        Content="Обновить"
                        Style="{StaticResource BaseButton}"
                        FontSize="12"
                        Margin="2"
                        Command="{Binding DetailCommand}"
                        CommandParameter="{Binding Style}"/>

                <Button Grid.Column="2"
                        Content="Удалить"
                        Style="{StaticResource DangerButton}"
                        FontSize="12"
                        Margin="2"
                        Command="{Binding DeleteParagraphStyleCommand}"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>