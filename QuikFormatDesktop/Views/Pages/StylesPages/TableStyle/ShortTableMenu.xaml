<UserControl x:Class="QuikFormatDesktop.Views.Pages.ShortTableMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220">

    <Border Background="{StaticResource BackColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BaseText}"
                       FontWeight="SemiBold"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Выравнивание:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding AlignmentNavigation.Name}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Текст:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding TextStyleNavigation.Name}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Абзац:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding ParagraphStyleNavigation.Name}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock Text="Граница:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding BorderThikness}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Text="px / "
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Text="{Binding BorderColor}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

            </StackPanel>

            <TextBlock Grid.Row="2"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Left"
                        Cursor="Hand"
                        Foreground="{StaticResource ForeColor}"
                        FontSize="12"
                        TextDecorations="Underline">
                Подробнее
            </TextBlock>

            <UniformGrid Grid.Row="3"
                         Margin="0,15,0,0"
                         Columns="2">

                <Button Content="Удалить"
                        Style="{StaticResource DangerButton}"
                        FontSize="12"
                        Margin="2"/>

                <Button Content="Обновить"
                        Style="{StaticResource BaseButton}"
                        FontSize="12"
                        Margin="2"/>
            </UniformGrid>

        </Grid>
    </Border>
</UserControl>