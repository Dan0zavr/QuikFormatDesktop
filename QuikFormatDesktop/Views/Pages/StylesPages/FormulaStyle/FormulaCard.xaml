<UserControl x:Class="QuikFormatDesktop.Views.Pages.FormulaCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.Views.Pages"
             xmlns:converters="clr-namespace:QuikFormatDesktop.Views.Converters"
             xmlns:enums="clr-namespace:QuikFormatDesktop.ViewModels.Enums"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:CodeToStringConverter x:Key="CodeToStringConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisible"/>
        <converters:ColorToHexConverter x:Key="ColorToHex"/>
    </UserControl.Resources>

    <GroupBox Header="{Binding CardName}" FontSize="14" Background="{StaticResource MainBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!--Имя стиля-->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Имя стиля:" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="FormulaStyleName" FontSize="12" Margin="0,0,0,5" Text="{Binding FormulaStyleName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Положение" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Rows="1" Margin="0,0,0,5">
                        <RadioButton GroupName="Position" Style="{StaticResource CenterLeftPosition}" 
                                     IsChecked="{Binding SelectedPosition,
                                     Converter={StaticResource EnumToBooleanConverter},
                                     ConverterParameter={x:Static enums:PositionType.CenterLeft}}"/>
                        <RadioButton GroupName="Position" Style="{StaticResource LeftRightPosition}"
                                     IsChecked="{Binding SelectedPosition,
                                     Converter={StaticResource EnumToBooleanConverter},
                                     ConverterParameter={x:Static enums:PositionType.LeftRight}}"/>
                        <RadioButton GroupName="Position" Style="{StaticResource RightLeftPosition}"
                                     IsChecked="{Binding SelectedPosition,
                                     Converter={StaticResource EnumToBooleanConverter},
                                     ConverterParameter={x:Static enums:PositionType.RightLeft}}"/>
                        <RadioButton GroupName="Position" Style="{StaticResource CenterRightPosition}"
                                     IsChecked="{Binding SelectedPosition,
                                     Converter={StaticResource EnumToBooleanConverter},
                                     ConverterParameter={x:Static enums:PositionType.CenterRight}}"/>
                    </UniformGrid>

                    <StackPanel Grid.Row="1" Margin="0, 5, 0, 0" Orientation="Horizontal">
                        <TextBlock Text="Пустые строки перед и после рисунка" FontSize="12" Margin="0, 0, 5, 0"/>
                        <CheckBox VerticalAlignment="Center" IsChecked="{Binding InsertBlankLines}"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Нумерация" FontSize="12" Margin="0,0,5,5"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource InnerBorderColor}" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Нумерация" FontSize="12" VerticalAlignment="Center"/>
                        <CheckBox Margin="5, 0, 0, 0" FontSize="12" VerticalAlignment="Center" IsChecked="{Binding IsNumberingEnabled}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0, 5, 0, 0" Orientation="Horizontal" Visibility="{Binding IsNumberingEnabled, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Формат нумерации" FontSize="12"/>
                        <ComboBox FontSize="12" Margin="5, 0, 0, 0" Width="60"
                                  ItemsSource="{Binding NumberingFormats}"
                                  SelectedItem="{Binding SelectedNumberingFormat}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Marker1, Converter={StaticResource CodeToStringConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="6" VerticalAlignment="Bottom" HorizontalAlignment="Right" >
                <StackPanel Orientation="Horizontal">
                    <StackPanel>
                        <Button Content="Сброс" Width="100" Margin="0,0,10,0" Command="{Binding ResetCommand}" Visibility="{Binding IsEdit, Converter={StaticResource InverseBoolToVisible}}"/>
                        <Button Content="Отмена" Width="100" Margin="0,0,10,0" Command="{Binding ResetCommand}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" x:Name="ForPopup">
                        <Button Content="Добавить" Width="100" Command="{Binding AddFormulaCommand}" Visibility="{Binding IsEdit, Converter={StaticResource InverseBoolToVisible}}"/>
                        <Button Content="Обновить" Width="100" Command="{Binding UpdateFormulaCommand}" Visibility="{Binding IsEdit, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    
                    <Popup IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
                           Placement="Top"
                           PlacementTarget="{Binding ElementName=ForPopup}"
                           StaysOpen="False">
                        <Border Background="{Binding PopupBackground, Converter={StaticResource ColorToHex}}" Padding="7" MaxWidth="100">
                            <TextBlock Text="{Binding PopupMessage}" TextWrapping="WrapWithOverflow" Foreground="{Binding PopupForeground, Converter={StaticResource ColorToHex}}" FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                    </Popup>
                </StackPanel>
            </StackPanel>
        </Grid>
    </GroupBox>
</UserControl>
