<UserControl x:Class="QuikFormatDesktop.Views.Pages.ShortNumberingMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:QuikFormatDesktop.Views.Converters"
             xmlns:vm="clr-namespace:QuikFormatDesktop.ViewModels.StylesViewModels"
             xmlns:pages="clr-namespace:QuikFormatDesktop.Views.Pages"
             Width="220">

    <UserControl.Resources>
        <converters:MarkerConverter x:Key="MarkerConverter"/>

        <DataTemplate DataType="{x:Type vm:NumberingStyleViewModel}">
            <pages:NumberingPage />
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{StaticResource BackColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BaseText}"
                       FontWeight="SemiBold"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Маркер:"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>

                    <TextBlock Margin="5,0,0,0"
                               Text="{Binding Marker, Converter={StaticResource MarkerConverter}}"
                               Style="{StaticResource BaseText}"
                               FontSize="12"/>
                </StackPanel>

            </StackPanel>

            <Grid Grid.Row="2" Margin="0,15,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Обновить"
                        Style="{StaticResource BaseButton}"
                        FontSize="12"
                        Margin="2"
                        Command="{Binding DetailCommand}"
                        CommandParameter="{Binding Style}"/>

                <Button Grid.Column="2"
                        Content="Удалить"
                        Style="{StaticResource DangerButton}"
                        FontSize="12"
                        Margin="2"
                        Command="{Binding DeleteNumberingStyleCommand}"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>