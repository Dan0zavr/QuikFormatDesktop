<UserControl x:Class="QuikFormatDesktop.Views.Pages.ShortTemplateMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuikFormatDesktop.Views.Pages"
             mc:Ignorable="d" 
             Width="220">
    <Border Padding="10" Background="{StaticResource BackColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="16" Style="{StaticResource BaseText}" HorizontalAlignment="Center"/>

            <StackPanel Grid.Row="1" Margin="0, 5, 0, 0">
                <TextBlock Style="{StaticResource BaseText}" FontSize="12" Text="Описание:"/>
                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="2">
                    <ScrollViewer Height="70">
                        <TextBlock Text="{Binding Description}" HorizontalAlignment="Left" TextWrapping="Wrap" Style="{StaticResource BaseText}" FontSize="12"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                Content="Удалить"
                Style="{StaticResource DangerButton}"
                FontSize="12"
                Margin="2"
                Command="{Binding DeleteCommand}"/>

                <Button Grid.Column="2"
                Content="Подробнее"
                Style="{StaticResource BaseButton}"
                FontSize="12"
                Margin="2"
                Command="{Binding DetailCommand}"
                CommandParameter="{Binding Style}"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>
