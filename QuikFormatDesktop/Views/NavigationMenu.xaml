<UserControl x:Class="QuikFormatDesktop.Views.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:QuikFormatDesktop.Views"
             xmlns:shortmenu="clr-namespace:QuikFormatDesktop.ViewModels.ShortMenuViewModels"
             xmlns:vm="clr-namespace:QuikFormatDesktop.ViewModels.ShortMenuViewModels"
             xmlns:pages="clr-namespace:QuikFormatDesktop.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="160"
             Background = "{StaticResource BackColor}">

    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource MyScrollBar}"/>

        <DataTemplate DataType="{x:Type vm:TextShortMenuViewModel}">
            <pages:ShortTextMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ParagraphShortMenuViewModel}">
            <pages:ShortParagraphMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TableShortMenuViewModel}">
            <pages:ShortTableMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:NumberedNumberingShortMenuViewModel}">
            <pages:ShortNumberingMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MarkedNumberingShortMenuViewModel}">
            <pages:ShortNumberingMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PictureShortMenuViewModel}">
            <pages:ShortPictureMenu/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FormulaShortMenuViewModel}">
            <pages:ShortFormulaMenu/>
        </DataTemplate>
    </UserControl.Resources>


    <Border BorderThickness="0,0,2,0" BorderBrush="{StaticResource BorderColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Button Content="Лого" Style="{StaticResource BaseButton}" Margin="4,10,4,10" Height="45" Command="{Binding GoToFormat}"/>
                <StackPanel Margin="4,10,4,10">
                    <Button Content="Форматировать" Style="{StaticResource BaseButton}" FontSize="14" Height="25" Command="{Binding GoToFormat}"/>
                    <Button Content="Стили" Style="{StaticResource BaseButton}" FontSize="14" Height="25" Margin="0,5,0,0" Command="{Binding GoToStyles}"/>
                </StackPanel>
            </StackPanel>

            <GroupBox Grid.Row="1" Header="{Binding GroupBoxHeader}" MinHeight="100" Style="{StaticResource TemplateBox}" FocusVisualStyle="{x:Null}" Effect="{x:Null}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="StyleListBox" Grid.Row="0" Background="Transparent" BorderThickness="0" 
                             ItemsSource="{Binding ItemsView}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             HorizontalContentAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             ItemContainerStyle="{StaticResource Item}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,5,0,5"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                    </ListBox>

                    <Popup IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
                           Placement="Right"
                           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=ListBox}}"
                           StaysOpen="False">

                        <i:Interaction.Behaviors>
                            <local:ClosePopupOnOutsideClickBehavior />
                        </i:Interaction.Behaviors>

                        <ContentControl x:Name="PopupContent" Content="{Binding PopupViewModel}"/>

                    </Popup>

                    <Button Grid.Row="1" Content="+ Добавить шаблон" Margin="0,5,0,0" Style="{StaticResource BaseButton}" FontSize="12" Height="20">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="3"
                                        BorderBrush="Transparent"
                                        BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Row="2" Margin="4,10,4,10">
                <Button Content="Настройки" Style="{StaticResource BaseButton}" FontSize="14" Height="30"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
