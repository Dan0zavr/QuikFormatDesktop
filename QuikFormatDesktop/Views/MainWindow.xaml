<Window x:Class="QuikFormatDesktop.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuikFormatDesktop.View"
        xmlns:pages="clr-namespace:QuikFormatDesktop.View.Pages"
        xmlns:vms="clr-namespace:QuikFormatDesktop.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="490" Width="880">
    <Grid>
        <Grid.Resources>
            <DataTemplate DataType="{x:Type vms:FormatViewModel}">
                <pages:FormatPage/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:StylesViewModel}">
                <pages:StylesPage/>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="160"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <local:NavigationMenu Grid.Column="0" DataContext="{Binding NavigationViewModel}"/>
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>
