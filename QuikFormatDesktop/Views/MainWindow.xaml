<Window x:Class="QuikFormatDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuikFormatDesktop.Views"
        xmlns:pages="clr-namespace:QuikFormatDesktop.Views.Pages"
        xmlns:vms="clr-namespace:QuikFormatDesktop.ViewModels"
        xmlns:stylesvms="clr-namespace:QuikFormatDesktop.ViewModels.StylesViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="490" Width="880">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.Resources>
            <DataTemplate DataType="{x:Type vms:FormatViewModel}">
                <pages:FormatPage/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vms:StylesViewModel}">
                <pages:StylesPage1/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type stylesvms:TemplateViewModel}">
                <pages:TemplateModalWindow/>
            </DataTemplate>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="160"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <local:NavigationMenu Grid.Column="0" DataContext="{Binding NavigationViewModel}"/>
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>

        <Grid Grid.ColumnSpan="2" Visibility="{Binding IsModalOpen, Converter={StaticResource BoolToVis}}">

            <Border Background="#80000000" />

            <ContentControl Content="{Binding CurrentModalViewModel}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
