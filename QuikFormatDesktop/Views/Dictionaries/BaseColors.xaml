<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    
    <SolidColorBrush Color="{StaticResource Ocean}" x:Key="BackColor"/>
    <SolidColorBrush Color="{StaticResource Lime}" x:Key="ForeColor"/>
    <SolidColorBrush Color="{StaticResource LightOcean}" x:Key="HoverBackColor"/>
    <SolidColorBrush Color="{StaticResource LightLime}" x:Key="HoverForeColor"/>
    <SolidColorBrush Color="{StaticResource DarkOcean}" x:Key="ButtonColor"/>
    <SolidColorBrush Color="#1b3745" x:Key="BorderColor"/>
    <SolidColorBrush Color="LightGray" x:Key="InnerBorderColor"/>
    <SolidColorBrush x:Key="DeleteButtonColor" Color="#D9534F"/>
    <SolidColorBrush x:Key="DeleteHoverColor" Color="#C9302C"/>
    <SolidColorBrush x:Key="DeleteForeground" Color="White"/>

    <SolidColorBrush Color="{StaticResource SoftBlue}" x:Key="SecondBackColor"/>
    <SolidColorBrush Color="{StaticResource ButterYellow}" x:Key="BaseTextColor"/>
    <SolidColorBrush Color="{StaticResource LightSoftBlue}" x:Key="HoverSecondBackColor"/>
    <SolidColorBrush Color="{StaticResource LightButterYellow}" x:Key="HoverBaseTextzColor"/>

    <SolidColorBrush Color="{StaticResource White}" x:Key="MainBackground"/>

    <SolidColorBrush Color="{StaticResource DisabledDerkPcean}" x:Key="DisabledColor"/>
    <SolidColorBrush Color="#AAAAAA" x:Key="DisabledForeColor"/>

</ResourceDictionary>